<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:PJ.Gestures.Maui.Samples"
             xmlns:gridSplitter="clr-namespace:PJ.Gestures.Maui.Samples.Controls.GridSplitter"
             x:Class="PJ.Gestures.Maui.Samples.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

			<Color x:Key="GridSplitterIndicatorColor">#FF868686</Color>
			<SolidColorBrush x:Key="GridSplitterIndicatorBrush" Color="{StaticResource GridSplitterIndicatorColor}" />

			<Style TargetType="gridSplitter:GridSplitter">
				<Setter Property="ControlTemplate">
					<Setter.Value>
						<ControlTemplate>
							<Grid x:Name="PART_GridSplitter">
								<ContentPresenter
									Content="{TemplateBinding Element}"
									HorizontalOptions="Fill"
									VerticalOptions="Fill" />
							</Grid>
						</ControlTemplate>
					</Setter.Value>
				</Setter>
			</Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
